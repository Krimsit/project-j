{
  "$schema": "http://json-schema.org/schema",
  "$id": "ClientProject",
  "cli": "nx",
  "title": "Generate client project",
  "description": "Create client project files",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the client project to generate",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use as the client project?",
      "pattern": "^[a-zA-Z].*$",
      "x-priority": "important"
    }
  },
  "required": ["name"]
}
